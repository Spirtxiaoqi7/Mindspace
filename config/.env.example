# Server
MINDSPACE_APP_NAME=Mindspace Graph
MINDSPACE_HOST=127.0.0.1
MINDSPACE_PORT=8765
MINDSPACE_DEBUG=false
MINDSPACE_RUNTIME_DIR=runtime

# LLM: demo starts without network or API keys; use openai for a compatible endpoint.
MINDSPACE_LLM_MODE=demo
MINDSPACE_LLM_BASE_URL=https://api.deepseek.com
MINDSPACE_LLM_API_KEY=
MINDSPACE_LLM_MODEL=deepseek-chat

# TTS: siliconflow (production default) | cosyvoice | browser | mock
MINDSPACE_TTS_PROVIDER=siliconflow
MINDSPACE_TTS_SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
MINDSPACE_TTS_SILICONFLOW_API_KEY=
MINDSPACE_TTS_SILICONFLOW_MODEL=fnlp/MOSS-TTSD-v0.5
MINDSPACE_TTS_SILICONFLOW_VOICE=fnlp/MOSS-TTSD-v0.5:alex
MINDSPACE_TTS_SILICONFLOW_SAMPLE_RATE=24000
MINDSPACE_TTS_SILICONFLOW_GAIN=0
# Optional local clone chain (not packaged for production)
MINDSPACE_TTS_WORKER_URL=http://127.0.0.1:5055
MINDSPACE_TTS_REFERENCE_AUDIO=assets\audio\tts-reference.wav
MINDSPACE_TTS_REFERENCE_TEXT=
MINDSPACE_AUTO_TTS=false

# ASR: funasr | browser | mock | openai
MINDSPACE_ASR_PROVIDER=funasr
MINDSPACE_ASR_BASE_URL=ws://127.0.0.1:8766/ws
MINDSPACE_ASR_API_KEY=
MINDSPACE_ASR_MODEL=paraformer-zh-streaming
